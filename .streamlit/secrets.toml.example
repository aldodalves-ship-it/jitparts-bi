# Copie este arquivo para .streamlit/secrets.toml e preencha com seus dados.
# NÃO versione secrets.toml no GitHub.
#
# No Streamlit Cloud: Settings → Secrets → cole o conteúdo abaixo preenchido.

[mercadolivre]
ML_CLIENT_ID     = "seu_client_id_aqui"
ML_CLIENT_SECRET = "seu_client_secret_aqui"
ML_REFRESH_TOKEN = "seu_refresh_token_aqui"
ML_SELLER_ID     = "seu_seller_id_aqui"
